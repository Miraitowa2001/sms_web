# ============================================
# IoT设备管理服务配置文件
# ============================================
# 复制此文件为 .env 并修改配置

# 服务端口
PORT=3000

# ==================== 管理界面认证配置 ====================
# 用于 Web 管理界面的 HTTP Basic Auth
AUTH_ENABLED=true
AUTH_USERNAME=admin
AUTH_PASSWORD=your-secure-password-here

# ==================== 开发板推送接口认证配置 ====================
# 用于开发板数据推送接口的 API Key 认证
API_KEY_ENABLED=true
API_KEY=your-secure-api-key-here-change-this

# ==================== 通话录音配置 ====================
# 开发板 telRecUrl 使用的独立上传密钥（建议与 API_KEY 不同）
RECORDING_UPLOAD_KEY=your-recording-upload-key-here
# 单个 AMR 文件最大体积（MB）
RECORDING_MAX_SIZE_MB=50
# 录音保留天数；0 表示永久保留
RECORDING_RETENTION_DAYS=0
# 可选：自定义录音目录和数据库路径
# RECORDING_DIR=/app/data/recordings
# DATABASE_PATH=/app/data/lvyou.db

# ==================== AES加密配置 ====================
# 用于解密开发板上报的加密数据
AES_ENABLED=false
# KEY 和 IV 支持三种格式:
# 1. ASCII字符串: 1234567890123456 (必须16字节)
# 2. 十进制数组: 49,50,51,52,53,54,55,56,57,48,49,50,51,52,53,54
# 3. 十六进制数组: 0x31,0x32,0x33,0x34,0x35,0x36,0x37,0x38,0x39,0x30,0x31,0x32,0x33,0x34,0x35,0x36
AES_KEY=1234567890123456
AES_IV=1234567890123456
